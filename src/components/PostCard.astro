---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
}

const { title, description, date, tags, href } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
---

<a href={href} class="card" style="display:block; text-decoration:none; color:var(--color-text);">
  <time style="font-family:var(--font-mono); font-size:0.8rem; color:var(--color-text-muted);">{dateStr}</time>
  <h3 style="margin:0.5rem 0 0.3rem;">{title}</h3>
  <p style="font-size:0.9rem; color:var(--color-text-muted); margin-bottom:0.8rem;">{description}</p>
  <div class="tags">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
</a>
