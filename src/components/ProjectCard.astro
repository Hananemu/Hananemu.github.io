---
interface Props {
  title: string;
  description: string;
  tags: string[];
  href?: string;
  featured?: boolean;
  cta?: { label: string; href: string };
}

const { title, description, tags, href, featured = false, cta } = Astro.props;
---

<div class={`card ${featured ? 'featured' : ''}`}>
  {featured && <span class="featured-badge">Featured</span>}
  <h3 style="margin-bottom:0.4rem;">
    {href ? <a href={href}>{title}</a> : title}
  </h3>
  <p style="font-size:0.9rem; color:var(--color-text-muted); margin-bottom:0.8rem;">{description}</p>
  <div class="tags">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  {cta && (
    <a href={cta.href} class="cta-btn">{cta.label}</a>
  )}
</div>

<style>
  .featured {
    border-color: var(--color-accent);
    position: relative;
  }
  .featured-badge {
    position: absolute;
    top: -0.6rem;
    right: 1rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-family: var(--font-mono);
  }
  .cta-btn {
    display: block;
    margin-top: 1rem;
    padding: 0.6rem 1rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    text-align: center;
    border-radius: 6px;
    transition: opacity 0.2s, transform 0.2s;
  }
  .cta-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
